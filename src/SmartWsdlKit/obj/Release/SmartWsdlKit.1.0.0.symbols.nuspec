<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2012/06/nuspec.xsd">
  <metadata>
    <id>SmartWsdlKit</id>
    <version>1.0.0</version>
    <authors>Ramazan Erbasaran</authors>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <icon>icon.png</icon>
    <readme>README.md</readme>
    <projectUrl>https://github.com/erbasaran/SmartWsdlKit.NET</projectUrl>
    <description>SmartWsdlKit is a lightweight, high-performance, enterprise-grade WSDL and SOAP client toolkit for .NET. It eliminates the complexity of Visual Studio Connected Services, svcutil, and legacy WCF configs by providing a modern, developer-friendly fluent API. Supports SOAP 1.1/1.2, SwA/MTOM attachments, lightweight Polly-less retries and circuit breaker, diagnostics traffic inspector, WS-Security UsernameToken (plaintext/digest), NTLM, and WSDL to OpenAPI 3.x / JSON Schema conversion.</description>
    <copyright>Copyright © 2026 Ramazan Erbasaran</copyright>
    <tags>wsdl soap client soap11 soap12 xml xsd mtom swa resilience retry circuit-breaker diagnostics inspector wcf web-services dotnet-standard openapi json-schema</tags>
    <repository type="git" url="https://github.com/erbasaran/SmartWsdlKit.NET" />
    <dependencies>
      <group targetFramework=".NETStandard2.0">
        <dependency id="System.Text.Json" version="9.0.0" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
